{
  "__inputs": [
    {"name": "DS_PROMETHEUS", "label": "Prometheus", "type": "datasource", "pluginId": "prometheus", "pluginName": "Prometheus"},
    {"name": "DS_POSTGRES", "label": "Postgres", "type": "datasource", "pluginId": "postgres", "pluginName": "PostgreSQL"}
  ],
  "annotations": {"list": []},
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": {"type": "postgres", "uid": "${DS_POSTGRES}"},
      "description": "CQ coverage matrix — latest CQ test run results pivoted by domain x result.",
      "gridPos": {"h": 10, "w": 12, "x": 0, "y": 0},
      "id": 1,
      "options": {"showHeader": true},
      "targets": [
        {
          "datasource": {"type": "postgres", "uid": "${DS_POSTGRES}"},
          "rawSql": "WITH latest_run AS (SELECT id, results_json, pass_rate, created_at FROM cq_test_runs WHERE status = 'completed' ORDER BY created_at DESC LIMIT 1), expanded AS (SELECT (r->>'cq_id')::uuid AS cq_id, r->>'result' AS result FROM latest_run, jsonb_array_elements(results_json) AS r) SELECT cq.domain, e.result, count(*) AS n FROM expanded e JOIN competency_questions cq ON cq.id = e.cq_id GROUP BY cq.domain, e.result ORDER BY cq.domain, e.result;",
          "refId": "A",
          "format": "table"
        }
      ],
      "title": "CQ Coverage Matrix (latest run)",
      "type": "table"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "Schema type presence by ontology module. Shows which entity types are currently promoted in the schema (value=1 per present type; _other_ tail count shown separately). NOT graph instance counts — for population counts per type, a separate metric would be needed (D176).",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "bars", "lineWidth": 1, "fillOpacity": 80, "showPoints": "never"},
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 10, "w": 12, "x": 12, "y": 0},
      "id": 2,
      "options": {
        "legend": {"calcs": ["lastNotNull"], "displayMode": "list", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "single", "sort": "none"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "grace_ontology_entity_type_count{entity_type!=\"_other_\"}",
          "legendFormat": "{{ontology_module}} / {{entity_type}}",
          "refId": "A"
        }
      ],
      "title": "Schema Type Presence by Domain",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "postgres", "uid": "${DS_POSTGRES}"},
      "description": "Ontology schema version timeline — promotion events and activation state.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "points", "lineWidth": 1, "fillOpacity": 0, "showPoints": "always"},
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 10},
      "id": 3,
      "options": {
        "legend": {"calcs": ["lastNotNull"], "displayMode": "list", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "single", "sort": "none"}
      },
      "targets": [
        {
          "datasource": {"type": "postgres", "uid": "${DS_POSTGRES}"},
          "rawSql": "SELECT created_at AS time, version_number, source, is_active FROM ontology_versions WHERE created_at > $__timeFrom() AND created_at < $__timeTo() ORDER BY created_at ASC;",
          "refId": "A",
          "format": "time_series"
        }
      ],
      "title": "Schema Version Timeline",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "postgres", "uid": "${DS_POSTGRES}"},
      "description": "Current proposal queue breakdown by status.",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 18},
      "id": 4,
      "options": {"showHeader": true},
      "targets": [
        {
          "datasource": {"type": "postgres", "uid": "${DS_POSTGRES}"},
          "rawSql": "SELECT status, count(*) AS count FROM schema_proposals GROUP BY status ORDER BY count DESC;",
          "refId": "A",
          "format": "table"
        }
      ],
      "title": "Proposal Queue Status",
      "type": "table"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["grace", "ontology"],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "hide": 0,
        "current": {"text": "Prometheus", "value": "grace-prometheus"}
      },
      {
        "name": "DS_POSTGRES",
        "type": "datasource",
        "query": "postgres",
        "hide": 0,
        "current": {"text": "Postgres", "value": "grace-postgres"}
      }
    ]
  },
  "time": {"from": "now-6h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "GrACE Ontology Health",
  "uid": "grace-ontology-health",
  "version": 1,
  "weekStart": ""
}
