        "justifyMode": "center",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "grace_graph_orphan_node_count",
          "legendFormat": "orphans",
          "refId": "A"
        }
      ],
      "title": "Orphan Node Count",
      "type": "stat"
    },
    {
