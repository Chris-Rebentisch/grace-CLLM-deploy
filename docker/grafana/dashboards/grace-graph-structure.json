          "legendFormat": "{{relationship_type}}",
          "refId": "A"
        }
      ],
      "title": "Edge Total by Type",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
