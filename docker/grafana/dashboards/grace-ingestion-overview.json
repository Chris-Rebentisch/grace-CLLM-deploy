  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "Triage funnel — stacked time series of terminal triage outcomes by coarse tier_outcome label (D428).",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "bars", "lineWidth": 1, "fillOpacity": 80, "stacking": {"mode": "normal"}},
          "noValue": "No data yet"
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "id": 1,
      "options": {
        "legend": {"calcs": ["sum"], "displayMode": "list", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "single", "sort": "none"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "sum by (tier_outcome) (rate(grace_ingestion_emails_processed_total{source_name=~\"$source_name\"}[$__rate_interval]))",
          "legendFormat": "{{tier_outcome}}",
          "refId": "A"
        }
      ],
      "title": "Triage Funnel",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "Per-source run health — started / completed / failed by source_type (D428).",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "noValue": "No data yet"
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "id": 2,
      "options": {
        "orientation": "auto",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "sum by (source_type) (grace_ingestion_runs_started_total{source_type=~\"$source_type\"})",
          "legendFormat": "started {{source_type}}",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "sum by (source_type) (grace_ingestion_runs_completed_total{source_type=~\"$source_type\"})",
          "legendFormat": "completed {{source_type}}",
          "refId": "B"
