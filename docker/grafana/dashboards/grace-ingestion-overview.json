      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "sum by (le, tier) (rate(grace_ingestion_triage_duration_seconds_bucket{tier=~\"$tier\"}[$__rate_interval]))",
