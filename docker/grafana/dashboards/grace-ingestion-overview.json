          "legendFormat": "{{tier}} {{le}}",
          "refId": "A"
        }
      ],
      "title": "Per-Tier Duration Percentiles",
      "type": "heatmap"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
