  ],
  "panels": [
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "extraction_quality_problem — Signal A high + retrieval-precision drop. Drill-through to Signal Pipeline Overview for upstream signal detail.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "lineWidth": 1, "fillOpacity": 10, "showPoints": "never"},
          "min": 0,
          "max": 1,
          "unit": "percentunit",
          "links": [
            {"title": "Drill: Signal Pipeline Overview", "url": "/d/grace-signals-overview", "targetBlank": false}
          ]
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "id": 1,
      "options": {
        "legend": {"calcs": ["mean", "lastNotNull"], "displayMode": "list", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "single", "sort": "none"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "max(grace_correlation_extraction_quality_problem_strength{job=\"grace_init\"})",
          "legendFormat": "extraction_quality_problem",
          "refId": "A"
        }
      ],
      "title": "Pattern — extraction_quality_problem",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "graph_or_index_problem — retrieval latency p95 spike + all six signals depressed. Drill-through to Signal Pipeline Overview.",
      "fieldConfig": {
        "defaults": {
