    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "schema_drift_per_module — Signal C and Signal D both elevated for the same ontology module. Drill-through to Signal Pipeline Overview.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "lineWidth": 1, "fillOpacity": 10, "showPoints": "never"},
          "min": 0,
          "max": 1,
          "unit": "percentunit",
          "links": [
            {"title": "Drill: Signal Pipeline Overview", "url": "/d/grace-signals-overview", "targetBlank": false}
          ]
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "id": 3,
      "options": {
        "legend": {"calcs": ["mean", "lastNotNull"], "displayMode": "list", "placement": "bottom", "showLegend": true},
        "tooltip": {"mode": "single", "sort": "none"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "max by (ontology_module) (grace_correlation_schema_drift_per_module_strength{job=\"grace_init\"})",
          "legendFormat": "{{ontology_module}}",
          "refId": "A"
        }
      ],
      "title": "Pattern — schema_drift_per_module",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "description": "cq_regression_pre_extraction — Signal F elevated + Mann-Kendall non-decreasing trend on triple-confidence. Drill-through to Signal Pipeline Overview.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "lineWidth": 1, "fillOpacity": 10, "showPoints": "never"},
          "min": 0,
