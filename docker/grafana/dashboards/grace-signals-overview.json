    {
      "datasource": {"type": "postgres", "uid": "${DS_POSTGRES}"},
      "description": "Recent signal-pipeline runs (signal_runs + analytics_signals join, latest 50).",
      "fieldConfig": {
        "defaults": {"color": {"mode": "thresholds"}, "custom": {"align": "auto"}},
        "overrides": []
      },
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 24},
      "id": 7,
      "options": {
        "showHeader": true
      },
      "targets": [
        {
          "datasource": {"type": "postgres", "uid": "${DS_POSTGRES}"},
          "format": "table",
          "rawSql": "SELECT started_at, status, signal_type, ontology_module, strength FROM signal_runs JOIN analytics_signals ON analytics_signals.run_id = signal_runs.id WHERE started_at > $__timeFrom() AND started_at < $__timeTo() ORDER BY started_at DESC LIMIT 50;",
          "refId": "A"
        }
      ],
      "title": "Recent Signal Runs",
      "type": "table"
