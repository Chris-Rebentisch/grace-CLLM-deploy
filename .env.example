# =============================================================================
# GrACE — runtime configuration (.env)
# Copy this file to `.env` and fill in the values marked CHANGEME / <...>.
# `.env` is gitignored and must never be committed. Never paste real secrets
# anywhere but your local `.env`.
# =============================================================================

# --- LLM (Claude-as-the-LLM deployment) -------------------------------------
# Your Anthropic API key (starts with sk-ant-). Required: the in-app LLM
# provider defaults to Anthropic (see config/discovery.yaml). You can also run
# `bash scripts/set-api-key.sh` to set this interactively.
LLM_API_KEY=<your-anthropic-api-key>

# --- Local model server (Ollama) — STILL REQUIRED ---------------------------
# Even with the Anthropic chat provider, Ollama is required for embeddings
# (nomic-embed-text) and a small local model used by specific pipeline stages.
# Install Ollama, then: `ollama pull nomic-embed-text` and `ollama pull qwen2.5:7b`.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_MAX_LOADED_MODELS=2
OLLAMA_USE_MLX=false

# --- PostgreSQL --------------------------------------------------------------
# Main relational store. Replace <user> with your local Postgres user.
DATABASE_URL=postgresql+psycopg2://<user>@localhost:5432/grace

# --- ArcadeDB (graph database) ----------------------------------------------
ARCADE_HOST=localhost
ARCADE_PORT=2480
ARCADE_USERNAME=root
ARCADE_PASSWORD=gracedev
ARCADE_DATABASE=grace
ARCADE_TIMEOUT=30

# --- API / server ------------------------------------------------------------
GRACE_HOST=localhost
GRACE_PORT=8000
METRICS_ENDPOINT_PATH=/metrics
# Set GRACE_ADMIN_KEY to a 32-byte random hex when deploying off localhost
# (python3 -c "import secrets; print(secrets.token_hex(32))"). Leave unset for
# localhost-only installs. Comma-separated CORS origins for the frontend.
GRACE_ADMIN_KEY=
GRACE_CORS_ORIGINS=
# Permission enforcement is OFF by default (a fresh system has no ratified
# permission matrix). Enable only after ratifying a matrix for your principal.
GRACE_PERMISSION_ENFORCEMENT_ENABLED=0

# --- MCP server (Claude Desktop / Claude Code integration) ------------------
MCP_GRACE_BASE_URL=http://127.0.0.1:8000
MCP_TIMEOUT_SECONDS=30

# --- Document processing (macOS OpenMP/Docling stability) -------------------
KMP_DUPLICATE_LIB_OK=TRUE
OMP_NUM_THREADS=1
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1

# --- Observability (Prometheus / Grafana / OpenTelemetry) -------------------
GRAFANA_POSTGRES_PASSWORD=CHANGEME
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=gracedev
OTEL_SERVICE_NAME=grace
OTEL_SERVICE_VERSION=1.0.0
OTEL_ENVIRONMENT=production
OTEL_TRACES_ENABLED=true
OTEL_METRICS_ENABLED=true
OTEL_LOGS_ENABLED=true
OTEL_TRACES_EXPORTER=otlp
OTEL_METRICS_EXPORTER=prometheus
OTEL_SEMCONV_STABILITY_OPT_IN=http
# Unix path. On Windows set e.g. C:\Temp\grace-prometheus-multiproc, or leave
# unset if you're not running the observability stack.
PROMETHEUS_MULTIPROC_DIR=/tmp/grace-prometheus-multiproc

# --- Frontend ----------------------------------------------------------------
NEXT_PUBLIC_GRACE_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_GRACE_APP_VERSION=1.0.0
NEXT_TELEMETRY_DISABLED=1

# --- Misc tunables -----------------------------------------------------------
GRAPH_HEALTH_EXPORTER_INTERVAL_SECONDS=60
GRAPH_HEALTH_EXPORTER_TOPN=20
ONTOLOGY_METRIC_TOPN=20
REGENERATION_TOTAL_INPUT_BUDGET_TOKENS=8000
