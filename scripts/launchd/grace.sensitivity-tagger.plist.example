<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.grace.sensitivity-tagger</string>

    <key>ProgramArguments</key>
    <array>
        <string>/opt/homebrew/opt/python@3.14/bin/python3.14</string>
        <string>-m</string>
        <string>src.ingestion.communications.sensitivity_tagger</string>
        <string>run</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/YOUR_USERNAME/grace</string>

    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>4</integer>
        <key>Minute</key>
        <integer>30</integer>
    </dict>

    <key>StandardOutPath</key>
    <string>/tmp/grace-sensitivity-tagger.stdout.log</string>

    <key>StandardErrorPath</key>
    <string>/tmp/grace-sensitivity-tagger.stderr.log</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PYTHONPATH</key>
        <string>/Users/YOUR_USERNAME/grace</string>
    </dict>
</dict>
</plist>
