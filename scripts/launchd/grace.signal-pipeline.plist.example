<?xml version="1.0" encoding="UTF-8"?>
<!--
  Example launchd plist for the GrACE Signal Computation Pipeline (Chunk 32).

  Operational model (D246): the pipeline is CLI-only. APScheduler / FastAPI
  lifespan integration is intentionally omitted. Operators schedule the CLI
  via host cron / launchd.

  Install (per-user):
    1. Copy this file to ~/Library/LaunchAgents/com.grace.signal-pipeline.plist
    2. Edit the placeholders:
       - GRACE_HOME       -> absolute path to your grace checkout
       - PYTHON_BIN       -> absolute path to the Python you used to install
                             pymannkendall (`python3 -m pip --version` → bin)
    3. Load it:           launchctl load ~/Library/LaunchAgents/com.grace.signal-pipeline.plist
    4. Verify:            launchctl list | grep com.grace.signal-pipeline

  Schedule below runs the pipeline once an hour. Adjust StartCalendarInterval
  to match your operational tempo. The CLI exits 0 on success, 1 on partial
  failure, 2 on hard error — launchd will record these in the system log.
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.grace.signal-pipeline</string>

    <key>ProgramArguments</key>
    <array>
        <string>/PYTHON_BIN</string>
        <string>-m</string>
        <string>src.analytics.signal_pipeline</string>
        <string>run-all</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/GRACE_HOME</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PYTHONPATH</key>
        <string>/GRACE_HOME</string>
    </dict>

    <key>StartCalendarInterval</key>
    <dict>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <key>StandardOutPath</key>
    <string>/GRACE_HOME/.build-state/grace-signal-pipeline.stdout.log</string>

    <key>StandardErrorPath</key>
    <string>/GRACE_HOME/.build-state/grace-signal-pipeline.stderr.log</string>

    <key>RunAtLoad</key>
    <false/>
</dict>
</plist>
